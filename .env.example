# ─── WaboxApp Monitor — Variáveis de Ambiente ───────────────────────────────
# Copie este arquivo para .env e preencha. NUNCA commite o .env real.

# ─── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Banco de dados MySQL (SiteGround) ──────────────────────────────────────
# Formato: mysql://USER:PASS@HOST:PORT/DBNAME
# No SiteGround Cloud, normalmente:
#   - HOST: 127.0.0.1 (localhost do servidor)
#   - PORT: 3306
#   - USER/PASS/DB: criados no Site Tools → MySQL
DATABASE_URL=mysql://USUARIO:SENHA@127.0.0.1:3306/NOME_DO_BANCO

# ─── Autenticação ──────────────────────────────────────────────────────────
# Segredo usado para assinar JWT. Gere um aleatório forte:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=COLE_AQUI_UM_SEGREDO_DE_64_CHARS_HEX

# Senha de acesso ao painel (login simples)
PANEL_PASSWORD=TROQUE_PARA_UMA_SENHA_FORTE

# ─── Cookie / path ─────────────────────────────────────────────────────────
# Caminho do cookie de sessão. Use "/monitor" quando o app rodar sob /monitor.
# Use "/" se rodar na raiz de um subdomínio dedicado.
COOKIE_PATH=/monitor

# ─── URL pública (opcional, usada em logs e webhook display) ───────────────
PUBLIC_URL=https://sougni.com/monitor

# ─── Keep-alive ────────────────────────────────────────────────────────────
# Define como "false" para desligar o self-ping de 5 min (não precisa em produção PM2).
KEEP_ALIVE_ENABLED=false
